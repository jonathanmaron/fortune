{
    "name": "jonathanmaron/fortune",
    "description": "Unix-style fortune program that displays a random quotation.",
    "license": "BSD-3-Clause",
    "type": "project",
    "require": {
        "php": "^8.5",
        "ext-intl": "*",
        "ext-json": "*",
        "psr/container": "^1.0 || ^2.0",
        "ramsey/uuid": "^4.0",
        "riimu/kit-phpencoder": "^3.0",
        "symfony/console": "^8.0",
        "symfony/filesystem": "^8.0",
        "symfony/finder": "^8.0",
        "symfony/lock": "^8.0"
    },
    "require-dev": {
        "ctw/ctw-qa": "^6.0",
        "phpunit/phpunit": "^13.0",
        "symfony/var-dumper": "^8.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "src"
        },
        "files": [
            "consts.php",
            "bootstrap.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "AppTest\\": "test"
        }
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "ecs": "php vendor/bin/ecs --clear-cache",
        "ecs-fix": "php vendor/bin/ecs --clear-cache --fix",
        "phpstan": "bash vendor/ctw/ctw-qa/bin/phpstan.sh",
        "phpstan-baseline": "bash vendor/ctw/ctw-qa/bin/phpstan-baseline.sh",
        "qa": [
            "@rector",
            "@ecs",
            "@phpstan"
        ],
        "qa-fix": [
            "@rector-fix",
            "@ecs-fix",
            "@phpstan"
        ],
        "rector": "php vendor/bin/rector process --clear-cache --dry-run",
        "rector-fix": "php vendor/bin/rector process --clear-cache",
        "test": "export XDEBUG_MODE=coverage ; php vendor/bin/phpunit"
    }
}
